# ---- Application ----
APP_NAME=Symphony
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=info

# ---- Server ----
HOST=0.0.0.0
PORT=8000

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://symphony:symphony_local@localhost:5432/symphony

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- CORS ----
CORS_ORIGINS=["http://localhost:3000"]

# ---- LLM / LangChain ----
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
DEFAULT_MODEL=gpt-4o

# ---- Brave Web Search ----
BRAVE_API_KEY=

# ---- LangSmith ----
LANGSMITH_TRACING=false
LANGSMITH__API_KEY=
LANGCHAIN_PROJECT=symphony
LANGCHAIN_ENDPOINT=
