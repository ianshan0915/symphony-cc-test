# ---- Application ----
APP_NAME=Symphony
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=info

# ---- Server ----
HOST=0.0.0.0
PORT=8000

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/symphony

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- CORS ----
CORS_ORIGINS=["http://localhost:3000"]

# ---- LLM / LangChain ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_MODEL=gpt-4o

# ---- LangSmith ----
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=symphony
